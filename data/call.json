[
  { "zh": "喂？……是我。", "ja": "もしもし？……俺だ。", "py": "wéi? … shì wǒ." },
  { "zh": "我就想听听你的声音。", "ja": "ただ、君の声が聞きたかった。", "py": "wǒ jiù xiǎng tīngting nǐ de shēngyīn." },
  { "zh": "……怎么不说话。", "ja": "……なんで黙ってるんだ。", "py": "… zěnme bù shuōhuà." },
  { "zh": "算了。听我说就行。", "ja": "まあいい。俺の声、聞いてればいい。", "py": "suàn le. tīng wǒ shuō jiù xíng." },
  { "zh": "今天也辛苦了。", "ja": "今日もお疲れさま。", "py": "jīntiān yě xīnkǔ le." },
  { "zh": "早点睡。……晚安。", "ja": "早く寝ろよ。……おやすみ。", "py": "zǎodiǎn shuì. … wǎn’ān." }
